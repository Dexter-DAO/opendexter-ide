{
  "name": "@dexterai/opendexter",
  "version": "1.7.2",
  "description": "OpenDexter - x402 search and discovery layer for AI agents. Search the OpenDexter catalog, check pricing, and pay with automatic USDC settlement.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "opendexter": "dist/index.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE",
    "skills",
    "rules",
    "agents",
    "commands",
    ".cursor-plugin",
    "cursor-mcp.json"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-widgets.mjs",
    "dev": "tsx src/index.ts",
    "pack:verify": "node ./verify-pack-no-sourcemaps.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run pack:verify",
    "release": "npm version patch && npm publish --access public",
    "test:fresh-install": "bash scripts/test-fresh-install.sh"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@dexterai/x402": "^2.0.0",
    "@dexterai/x402-core": "^1.3.0",
    "@dexterai/x402-mcp-tools": "^0.1.0",
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0",
    "@x402/core": "^2.6.0",
    "@x402/extensions": "^2.6.0",
    "bs58": "^6.0.0",
    "chalk": "^5.6.2",
    "ethers": "^6.13.0",
    "tweetnacl": "^1.0.3",
    "viem": "^2.0.0",
    "yargs": "^17.7.2",
    "zod": "^3.23.0",
    "@dexterai/mcp-instructions": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/yargs": "^17.0.33",
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "opendexter",
    "x402",
    "mcp",
    "dexter",
    "solana",
    "base",
    "evm",
    "payments",
    "ai-agents",
    "marketplace",
    "chatgpt",
    "cursor",
    "claude"
  ],
  "author": "Dexter",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dexter-DAO/opendexter-ide",
    "directory": "packages/mcp"
  },
  "homepage": "https://dexter.cash/opendexter"
}
