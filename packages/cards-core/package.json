{
  "name": "@dexterai/cards-core",
  "version": "0.2.0",
  "description": "TypeScript HTTP client for the MoonPay MoonAgents Card API (agents.moonpay.com). Mirrors the public MoonPay CLI's wire format. Used by Dexter to issue and manage MoonAgents Cards programmatically.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --clean && tsc --emitDeclarationOnly --outDir dist",
    "dev": "tsup src/index.ts --format esm,cjs --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "release": "npm version patch && npm publish --access public"
  },
  "keywords": [
    "moonpay",
    "moonagents",
    "card",
    "dexter",
    "mastercard",
    "x402",
    "stablecoin"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Dexter-DAO/opendexter-ide.git",
    "directory": "packages/cards-core"
  }
}
