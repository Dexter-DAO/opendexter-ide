{
  "name": "@dexterai/dextercard",
  "version": "0.4.0",
  "description": "Dextercard SDK — issue and manage virtual cards for AI agents. Wraps a regulated card-issuance carrier with a clean TypeScript API, self-managed sessions, and a captcha-aware login flow.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "_build_note": "DO NOT add --sourcemap to tsup. Sourcemaps would expose original TS source, comments, and architecture to anyone who runs `npm install`. See .npmignore.",
    "build": "tsup src/index.ts --format esm,cjs --clean --no-sourcemap && tsc --emitDeclarationOnly --outDir dist",
    "dev": "tsup src/index.ts --format esm,cjs --watch --no-sourcemap",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && node ./scripts/check-no-sourcemaps.cjs",
    "release": "npm version patch && npm publish --access public"
  },
  "keywords": [
    "dextercard",
    "dexter",
    "card",
    "agents",
    "stablecoin",
    "x402",
    "mastercard"
  ],
  "license": "MIT",
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Dexter-DAO/opendexter-ide.git",
    "directory": "packages/dextercard"
  }
}
